# Usage:
# - copy to: compose.env
# - then run: docker compose --env-file compose.env up -d --build

# App
NODE_ENV=development
HTTP_PORT=80

# Database (Postgres container)
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_DATABASE=camera_store

# Auth
JWT_SECRET=change-me-super-secret
JWT_EXPIRATION=7d

# CORS: comma-separated list of allowed browser origins (no trailing slash)
# Example:
# CORS_ORIGINS=https://your-frontend.vercel.app,https://yourdomain.com
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

